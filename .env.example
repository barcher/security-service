# security-service — Environment Variable Reference
# Copy this file to .env and fill in deployment-specific values:
#
#   cp .env.example .env
#
# The .env file is gitignored. Never commit secrets to version control. Production deployments
# should source values from k8s Secrets / docker-compose `secrets` blocks — env vars are the
# local-dev convenience path.

# ── Server bind ──────────────────────────────────────────────────────────────
# Listening interface + port. mTLS terminates on this port once Stream E lands the SSL
# connector; until then the listener is plaintext and every request is rejected with 401
# (DenyAllPeerCertChainExtractor is the default binding).
SECURITY_SERVICE_HOST=0.0.0.0
SECURITY_SERVICE_PORT=8443

# ── mTLS keystore + truststore (Stream E activates these) ────────────────────
# Both files are PKCS12 (RFC 7292) — produce with: openssl pkcs12 -export …
# Server cert under SECURITY_SERVICE_KEYSTORE_ALIAS must be ECDSA P-384 (secp384r1)
# per the proposal §7.2 TLS row. The truststore holds the CA cert that signed every
# accepted client cert.
SECURITY_SERVICE_KEYSTORE_PATH=/run/secrets/security-service/keystore.p12
SECURITY_SERVICE_KEYSTORE_PASSWORD=changeme
SECURITY_SERVICE_KEYSTORE_ALIAS=security-service
SECURITY_SERVICE_TRUSTSTORE_PATH=/run/secrets/security-service/truststore.p12
SECURITY_SERVICE_TRUSTSTORE_PASSWORD=changeme

# ── KEK key material ─────────────────────────────────────────────────────────
# Two mutually-exclusive sources, in priority order:
#
#   1. FileMountKekProvider (recommended for prod) reads from $KEK_MOUNT_DIR.
#      Mount a docker-secret / k8s Secret containing the two files:
#        - $KEK_MOUNT_DIR/ml_kem_public_key   (base64, ~1580 chars; raw 1184 bytes)
#        - $KEK_MOUNT_DIR/ml_kem_private_key  (base64, ~3204 chars; raw 2400 bytes)
#      Plaintext base64 in the file is fine — the secret store provides confidentiality at
#      rest. File-mount keeps key material off /proc/<pid>/environ and `ps eww`.
#
#   2. MlKemService.fromEnv() reads ML_KEM_PUBLIC_KEY / ML_KEM_PRIVATE_KEY directly.
#      Acceptable for local dev only; never use in prod.
#
# Leave both unset to fall back to NoOpCryptoKeyService — the service starts but throws on
# every wrap/unwrap attempt. Useful for `/v1/health` smoke-testing the listener.
KEK_MOUNT_DIR=/run/secrets/kek
ML_KEM_PUBLIC_KEY=
ML_KEM_PRIVATE_KEY=

# ── Admin allow-list (SKS-B04) ───────────────────────────────────────────────
# Semicolon-separated full RFC2253 subject DNs of clients permitted to invoke admin routes
# under /v1/admin/. Use semicolons (not commas) — RFC2253 DNs contain commas internally.
#
# Example:
#   SECURITY_ADMIN_SUBJECTS=CN=admin-1,O=WorkAutomations;CN=admin-2,O=WorkAutomations
#
# When unset, the allow-list is empty and every authenticated caller receives HTTP 403 +
# ADMIN_FORBIDDEN audit on any /v1/admin/* endpoint.
SECURITY_ADMIN_SUBJECTS=

# ── Per-subject rate limit on /v1/dek/unwrap (SKS-B05) ───────────────────────
# Token-bucket limiter keyed by client mTLS subject DN. Over-cap calls return HTTP 429 +
# RATE_LIMIT_EXCEEDED audit event.
#
# SECURITY_UNWRAP_RATE_LIMIT_ENABLED: true (default) | false. Accepts
#   true/false/1/0/yes/no/on/off (case-insensitive). When false, the limiter is
#   bypassed entirely (no 429s, no audit on overflow). Never disable in prod.
#
# SECURITY_UNWRAP_RATE_LIMIT_CAPACITY: token-bucket capacity per subject DN. Must be > 0.
#   Defaults to 5. Each successful unwrap consumes 1 token.
#
# SECURITY_UNWRAP_RATE_LIMIT_REFILL_PER_SECOND: refill rate in tokens / second. Must be > 0.
#   Defaults to 1.0. With the defaults, a single subject sustains 1 unwrap/s long-term and
#   can burst up to 5.
#
# Operator note: in Stream B the limiter is strictly local-process. Horizontal scale-out
# multiplies the effective limit by replica count until Stream C lands the shared limiter.
SECURITY_UNWRAP_RATE_LIMIT_ENABLED=true
SECURITY_UNWRAP_RATE_LIMIT_CAPACITY=5
SECURITY_UNWRAP_RATE_LIMIT_REFILL_PER_SECOND=1.0
