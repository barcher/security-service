# security-service — Environment Variable Reference
# Copy this file to .env and fill in deployment-specific values:
#
#   cp .env.example .env
#
# The .env file is gitignored. Never commit secrets to version control. Production deployments
# should source values from k8s Secrets / docker-compose `secrets` blocks — env vars are the
# local-dev convenience path.

# ── Server bind ──────────────────────────────────────────────────────────────
# Listening interface + port. mTLS terminates on this port once Stream E lands the SSL
# connector; until then the listener is plaintext and every request is rejected with 401
# (DenyAllPeerCertChainExtractor is the default binding).
SECURITY_SERVICE_HOST=0.0.0.0
SECURITY_SERVICE_PORT=8443

# ── mTLS keystore + truststore (Stream E activates these) ────────────────────
# Both files are PKCS12 (RFC 7292) — produce with: openssl pkcs12 -export …
# Server cert under SECURITY_SERVICE_KEYSTORE_ALIAS must be ECDSA P-384 (secp384r1)
# per the proposal §7.2 TLS row. The truststore holds the CA cert that signed every
# accepted client cert.
#
# DEV: paths point at this service's own `./secrets/` tree, populated by
# `scripts/init-dev-certs.sh`. NO cross-service paths — the security service never reads
# from `../scaffold/` (see docs/TRUST_MODEL.md §2).
#
# PROD: these vars are unused — the Linkerd sidecar handles TLS termination + workload
# identity (docs/TRUST_MODEL.md §3).
SECURITY_SERVICE_KEYSTORE_PATH=./secrets/keystore.p12
SECURITY_SERVICE_KEYSTORE_PASSWORD=devpass
SECURITY_SERVICE_KEYSTORE_ALIAS=security-service
SECURITY_SERVICE_TRUSTSTORE_PATH=./secrets/truststore.p12
SECURITY_SERVICE_TRUSTSTORE_PASSWORD=devpass

# ── KEK key material ─────────────────────────────────────────────────────────
# Two mutually-exclusive sources, in priority order:
#
#   1. FileMountKekProvider (recommended for prod) reads from $KEK_MOUNT_DIR.
#      Mount a docker-secret / k8s Secret containing the two files:
#        - $KEK_MOUNT_DIR/ml_kem_public_key   (base64, ~1580 chars; raw 1184 bytes)
#        - $KEK_MOUNT_DIR/ml_kem_private_key  (base64, ~3204 chars; raw 2400 bytes)
#      Plaintext base64 in the file is fine — the secret store provides confidentiality at
#      rest. File-mount keeps key material off /proc/<pid>/environ and `ps eww`.
#
#   2. MlKemService.fromEnv() reads ML_KEM_PUBLIC_KEY / ML_KEM_PRIVATE_KEY directly.
#      Acceptable for local dev only; never use in prod.
#
# Leave both unset to fall back to NoOpCryptoKeyService — the service starts but throws on
# every wrap/unwrap attempt. Useful for `/v1/health` smoke-testing the listener.
#
# DEV: KEK_MOUNT_DIR points at this service's own `./secrets/` (the same dir as the mTLS
# material), populated by `scripts/init-dev-certs.sh`.
# PROD: KEK_MOUNT_DIR is mounted from a k8s Secret holding an HSM-wrapped KEK blob; the
# service unwraps at boot via PKCS#11. See docs/TRUST_MODEL.md §3.3.
KEK_MOUNT_DIR=./secrets
ML_KEM_PUBLIC_KEY=
ML_KEM_PRIVATE_KEY=

# ── Admin allow-list (SKS-B04) ───────────────────────────────────────────────
# Semicolon-separated full RFC2253 subject DNs of clients permitted to invoke admin routes
# under /v1/admin/. Use semicolons (not commas) — RFC2253 DNs contain commas internally.
#
# Example:
#   SECURITY_ADMIN_SUBJECTS=CN=admin-1,O=WorkAutomations;CN=admin-2,O=WorkAutomations
#
# When unset, the allow-list is empty and every authenticated caller receives HTTP 403 +
# ADMIN_FORBIDDEN audit on any /v1/admin/* endpoint.
SECURITY_ADMIN_SUBJECTS=

# ── Per-subject rate limit on /v1/dek/unwrap (SKS-B05) ───────────────────────
# Token-bucket limiter keyed by client mTLS subject DN. Over-cap calls return HTTP 429 +
# RATE_LIMIT_EXCEEDED audit event.
#
# SECURITY_UNWRAP_RATE_LIMIT_ENABLED: true (default) | false. Accepts
#   true/false/1/0/yes/no/on/off (case-insensitive). When false, the limiter is
#   bypassed entirely (no 429s, no audit on overflow). Never disable in prod.
#
# SECURITY_UNWRAP_RATE_LIMIT_CAPACITY: token-bucket capacity per subject DN. Must be > 0.
#   Defaults to 5. Each successful unwrap consumes 1 token.
#
# SECURITY_UNWRAP_RATE_LIMIT_REFILL_PER_SECOND: refill rate in tokens / second. Must be > 0.
#   Defaults to 1.0. With the defaults, a single subject sustains 1 unwrap/s long-term and
#   can burst up to 5.
#
# Operator note: in Stream B the limiter is strictly local-process. Horizontal scale-out
# multiplies the effective limit by replica count until Stream C lands the shared limiter.
SECURITY_UNWRAP_RATE_LIMIT_ENABLED=true
SECURITY_UNWRAP_RATE_LIMIT_CAPACITY=5
SECURITY_UNWRAP_RATE_LIMIT_REFILL_PER_SECOND=1.0

# ── Operational DB (Stream C) ────────────────────────────────────────────────
# Separate MySQL instance from the monolith's operational DB. Holds:
#   - security_keys.keks (lifecycle rows)
#   - security_keys.deks (wrapped DEKs)
#   - security_keys.audit_events (HMAC-SHA-512 chain)
#   - security_keys.legacy_key_index (Stream-E import-monolith-deks rows)
# `allowPublicKeyRetrieval=true` is required for MySQL 8.x default auth plugin
# (caching_sha2_password) when useSSL=false. Without it: `Public Key Retrieval is not
# allowed` at first connect. Drop the flag in prod where useSSL=true.
SECURITY_DB_URL=jdbc:mysql://localhost:3308/security_keys?useUnicode=true&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
SECURITY_DB_USER=security
SECURITY_DB_PASSWORD=changeme
SECURITY_DB_DRIVER=com.mysql.cj.jdbc.Driver

# ── Audit chain HMAC key (Stream C) ──────────────────────────────────────────
# 64 raw bytes, base64-encoded. Used to compute every audit_events row's `row_hmac` over
# `prev_hmac || canonical(event)`. Must be set; the service refuses to start without it.
#
# Generate locally with: openssl rand -base64 64 | tr -d '\n'
#
# Rotation is operator-driven and gated on a maintenance window; rotating this key WITHOUT
# also re-keying existing rows breaks `verifyChain` for everything written before the
# rotation. Treat it as a long-lived secret.
AUDIT_HMAC_KEY=

# ── Backup key (Stream C) ────────────────────────────────────────────────────
# 32 raw bytes, base64-encoded. Used by `KekBackupVerifyJob` to encrypt KEK backups for
# offsite storage independently of the KEK itself. Separating BACKUP_KEY from the KEK is
# the rule that prevents a single-key compromise from also losing the backup escrow.
#
# Generate locally with: openssl rand -base64 32 | tr -d '\n'
BACKUP_KEY=

# ── Cold storage / audit shipper (Stream E) ──────────────────────────────────
# Destination for shipped audit_events rows once they fall outside the hot-retention
# window. Set to a non-empty value to enable shipping; leave empty for dev (rows stay in
# the operational DB only).
#
# Format:
#   s3://<bucket>/<prefix>           — AWS S3 / S3-compatible
#   file:///<absolute-path>          — filesystem mount (dev only)
COLD_STORAGE_URL=

# ── Quartz cadences (Stream C) ───────────────────────────────────────────────
# Cron expressions for the six recurring jobs. All default to safe-for-prod values; tighten
# for dev by setting to */5 or similar. Quartz timezone is the JVM's default; set TZ env if
# you need UTC explicitly.
DEK_ROTATION_CRON=0 0 3 ? * SUN          # weekly DEK rewrap, Sundays 03:00
KEK_PRIOR_TTL_CRON=0 0 4 * * ?           # daily PRIOR-key retirement check, 04:00
KEK_ROTATION_HEALTH_CRON=0 0 * * * ?     # hourly wrap+unwrap probe
KEK_BACKUP_VERIFY_CRON=0 30 4 * * ?      # daily backup decrypt probe, 04:30
AUDIT_LOG_SHIP_CRON=0 0/15 * * * ?       # every 15 minutes
AUDIT_RETENTION_CRON=0 0 5 * * ?         # daily retention scan, 05:00

# ── Retention floor (Stream C) ───────────────────────────────────────────────
# Days of audit_events to retain in the operational DB. Defaults to 2557 days (7 years).
# Rows older than this are deleted ONLY after they've been shipped to COLD_STORAGE_URL —
# the retention job's deletion query is gated on `shipped_id IS NOT NULL`.
AUDIT_RETENTION_DAYS=2557

# Dev convenience: suppress HikariCP warnings produced when the Mac wakes from sleep.
# The JVM is paused during sleep, so keepalive cannot fire — on wake every pooled connection
# is detected as broken with a stack trace, which is noise rather than signal in development.
# Leave unset (or =false) in production so legitimate clock-leap / connection-broken warnings surface.
# LOG_SUPPRESS_HIKARI_SLEEP_NOISE=true
