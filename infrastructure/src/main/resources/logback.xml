<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <!--
      Drops HikariCP wake-from-sleep noise on dev machines when
      LOG_SUPPRESS_HIKARI_SLEEP_NOISE=true. Default off; prod is unaffected.
    -->
    <filter class="com.shared.security.infrastructure.logging.HikariSleepNoiseFilter"/>
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

  <logger name="io.ktor" level="INFO"/>
  <logger name="Exposed" level="WARN"/>
  <logger name="com.zaxxer.hikari" level="INFO"/>
  <logger name="org.flywaydb" level="INFO"/>

  <!--
    Netty's ApplicationProtocolNegotiationHandler logs every failed TLS handshake at WARN
    with the full stack trace. For an mTLS-required server, every anonymous client probe
    triggers this and floods the log. SslHandshakeExceptionHandler already emits a single
    INFO line for the same event with the relevant context (remote address + reason), so
    suppressing this class to ERROR loses no information.
  -->
  <logger name="io.netty.handler.ssl.ApplicationProtocolNegotiationHandler" level="ERROR"/>
</configuration>
